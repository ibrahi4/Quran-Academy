    "dev:backend": "cd backend && npm run start:dev",
    "dev": "concurrent
cd ibrahim-quran-academy

# ══════════════ CLEAN ══════════════
Remove-Item -Recurse -Force .\node_modules -ErrorAction SilentlyContinue
Remove-Item -Recurse -Force .\.next -ErrorAction SilentlyContinue

# ══════════════ MOVE FRONTEND ══════════════
New-Item -ItemType Directory -Force -Path .\frontend | Out-Null
Get-ChildItem -Force | Where-Object { .Name -notin @('.git', 'frontend') } | Move-Item -Destination .\frontend\

# ══════════════ ROOT PACKAGE.JSON ══════════════
@"
{
  "name": "ibrahim-quran-academy-monorepo",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run start:dev",
    "dev": "concurrently --names FE,BE --prefix-colors cyan,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:studio": "cd backend && npx prisma studio"
  },
  "devDependencies": {}
}
