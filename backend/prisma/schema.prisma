generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
  TRIAL_STUDENT
  GUEST
}

enum Locale {
  EN
  AR
}

enum Gender {
  MALE
  FEMALE
}

enum StudentLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  HAFIZ
}

enum BookingType {
  TRIAL
  REGULAR
  MAKEUP
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  MISSED
}
enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}
enum WalletTransactionType {
  SESSION_EARNING
  BONUS
  DEDUCTION
  PAYOUT
  REFUND
  ADJUSTMENT
}

enum WalletPayoutMethod {
  CASH
  BANK_TRANSFER
  PAYPAL
  VODAFONE_CASH
  INSTAPAY
  OTHER
}



enum Platform {
  ZOOM
  GOOGLE_MEET
  SKYPE
  TEAMS
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  STRIPE
  PAYPAL
  BANK_TRANSFER
}

enum SubscriptionPlan {
  TRIAL
  BASIC
  PREMIUM
  FAMILY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  SESSION_REMINDER
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_EXPIRING
  WELCOME
  GENERAL
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     Role   @default(GUEST)

  firstName String
  lastName  String
  phone     String?
  avatar    String?

  locale Locale @default(EN)

  isActive      Boolean @default(true)
  emailVerified Boolean @default(false)

  lastLoginAt          DateTime?
  mustChangePassword   Boolean   @default(false)
  trialEndsAt          DateTime?
  setupToken           String?   @unique
  setupTokenExpiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student?
  teacher Teacher?

  refreshTokens RefreshToken[]
  notifications Notification[]
  payments      Payment[]
  subscriptions Subscription[]
  testimonials  Testimonial[]
  blogPosts     BlogPost[]

  @@map("users")
}

model Teacher {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio         String?
  specialties String[]
  experience  Int      @default(0)
  rating      Float    @default(5.0)
  hourlyRate  Decimal  @default(15.00) @db.Decimal(10, 2)

  isActive Boolean @default(true)

  sessions  Session[]
  students  Student[]
  recurringSchedules RecurringSchedule[]
  wallet TeacherWallet?

  sessionReports SessionReport[]
  assignments    Assignment[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teachers")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Student {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  parentName String?
  age        Int?
  gender     Gender?
  country    String?
  city       String?
  timezone   String?

  level  StudentLevel @default(BEGINNER)
  goals  String[]
  notes  String?
  source String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]
  sessions Session[]
  progress Progress[]
  recurringSchedules RecurringSchedule[]

  sessionReports SessionReport[]
  assignments    Assignment[]
  submissions    AssignmentSubmission[]

  @@map("students")
}

model Progress {
  id        String  @id @default(uuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  surahsCompleted Int @default(0)
  juzCompleted    Int @default(0)
  tajweedScore    Int @default(0)
  memorization    Int @default(0)

  lastLesson String?
  notes      String?

  recordedAt DateTime @default(now())

  @@map("progress")
}

model Booking {
  id        String   @id @default(uuid())
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  name  String
  email String
  phone String?

  country  String?
  timezone String?

  preferredDate DateTime?
  preferredTime String?

  serviceSlug String?
  type        BookingType   @default(TRIAL)
  status      BookingStatus @default(PENDING)

  notes      String?
  adminNotes String?

  meetingLink String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session?

  @@map("bookings")
}

model Session {
  id String @id @default(uuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  title    String
  date     DateTime
  duration Int @default(60)

  status SessionStatus @default(SCHEDULED)

  meetingLink String?
  platform    Platform @default(ZOOM)

  recordingUrl String?

  notes        String?
  teacherNotes String?

  // ✅ Changed to nullable - only set when session is completed
  studentAttended Boolean?
  teacherAttended Boolean?

  studentLateMins Int @default(0)
  teacherLateMins Int @default(0)

  recurringScheduleId String?
  recurringSchedule   RecurringSchedule? @relation(fields: [recurringScheduleId], references: [id], onDelete: SetNull)

  walletTransactions WalletTransaction[]

  report      SessionReport?
  assignments Assignment[]

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, date])
  @@index([teacherId, date])
  @@index([status, date])
  @@map("sessions")
}


model RecurringSchedule {
  id    String @id @default(uuid())
  title String

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  // Schedule pattern
  daysOfWeek Int[]              // [0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat]
  time       String             // "09:00" - 24h format
  duration   Int                @default(60)
  frequency  RecurringFrequency @default(WEEKLY)

  // Date range
  startDate DateTime
  endDate   DateTime

  // Skip dates (holidays, vacations)
  skipDates DateTime[]

  // Session defaults
  platform    Platform @default(ZOOM)
  meetingLink String?
  notes       String?

  // Status
  isActive Boolean @default(true)

  // Stats
  totalGenerated Int @default(0)
  totalSkipped   Int @default(0)

  // Relations
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId, isActive])
  @@index([teacherId, isActive])
  @@map("recurring_schedules")
}

model TeacherWallet {
  id        String  @id @default(uuid())
  teacherId String  @unique
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  balance         Decimal @default(0) @db.Decimal(12, 2)
  totalEarned     Decimal @default(0) @db.Decimal(12, 2)
  totalPaid       Decimal @default(0) @db.Decimal(12, 2)
  totalBonuses    Decimal @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal @default(0) @db.Decimal(12, 2)

  currency String @default("USD")

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teacher_wallets")
}

model WalletTransaction {
  id       String        @id @default(uuid())
  walletId String
  wallet   TeacherWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type   WalletTransactionType
  amount Decimal               @db.Decimal(12, 2)

  category    String?
  description String  @db.Text

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  payoutMethod    WalletPayoutMethod?
  payoutReference String?
  receiptDate     DateTime?

  createdById   String
  createdByName String
  balanceAfter  Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
  @@index([type, createdAt])
  @@index([sessionId])
  @@map("wallet_transactions")
}
model Payment {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")

  status PaymentStatus @default(PENDING)

  stripePaymentId String? @unique
  stripeInvoiceId String?

  method PaymentMethod @default(STRIPE)

  description String?
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("payments")
}

model Subscription {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   SubscriptionPlan
  status SubscriptionStatus @default(ACTIVE)

  stripeSubId String? @unique

  sessionsPerWeek Int     @default(2)
  priceMonthly    Decimal @db.Decimal(10, 2)

  startDate   DateTime  @default(now())
  endDate     DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]

  @@index([userId, status])
  @@index([status])
  @@map("subscriptions")
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  channel NotificationChannel @default(IN_APP)

  title String
  body  String

  data Json?

  read   Boolean   @default(false)
  readAt DateTime?
  sentAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model BlogPost {
  id   String @id @default(uuid())
  slug String @unique

  titleEn String
  titleAr String?

  contentEn String @db.Text
  contentAr String? @db.Text

  excerptEn String?
  excerptAr String?

  coverImage String?

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  tags String[]

  locale      Locale    @default(EN)
  published   Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, publishedAt])
  @@index([authorId])
  @@map("blog_posts")
}

model Testimonial {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  name    String
  country String?
  avatar  String?

  textEn String @db.Text
  textAr String? @db.Text

  rating Int @default(5)

  videoUrl String?

  approved Boolean @default(false)
  featured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([approved, featured])
  @@map("testimonials")
}

model Contact {
  id      String  @id @default(uuid())
  name    String
  email   String
  phone   String?
  subject String?
  message String  @db.Text

  status ContactStatus @default(NEW)

  repliedAt DateTime?
  adminNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@map("contacts")
}

model AnalyticsEvent {
  id        String  @id @default(uuid())
  event     String
  page      String?
  metadata  Json?
  ip        String?
  userAgent String?
  locale    Locale?
  sessionId String?

  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([sessionId])
  @@map("analytics_events")
}

// ============================================================
// SESSION REPORTS
// ============================================================

enum SessionReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

model SessionReport {
  id        String @id @default(uuid())

  sessionId String @unique
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  status SessionReportStatus @default(DRAFT)

  // Attendance
  studentAttended Boolean @default(true)
  teacherAttended Boolean @default(true)
  studentLateMins Int     @default(0)
  teacherLateMins Int     @default(0)

  // Lesson content
  lessonSummary    String? @db.Text
  teacherNotes     String? @db.Text
  nextLessonFocus  String? @db.Text
  privateAdminNote String? @db.Text

  // Student evaluation (1-5)
  participationScore Int?
  recitationScore    Int?
  tajweedScore       Int?
  memorizationScore  Int?
  overallScore       Int?
  evaluationNotes    String? @db.Text

  // Trial assessment fields (only for trial sessions)
  isTrialAssessment      Boolean @default(false)
  recommendedLevel       StudentLevel?
  recommendedPlanNotes   String? @db.Text

  // Admin review
  adminDecisionNote  String? @db.Text
  reviewedByAdminId  String?
  submittedAt        DateTime?
  reviewedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments Assignment[]

  @@index([teacherId, status])
  @@index([studentId, status])
  @@index([status, createdAt])
  @@map("session_reports")
}

// ============================================================
// ASSIGNMENTS
// ============================================================

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

enum AssignmentSubmissionStatus {
  SUBMITTED
  LATE
  GRADED
  RETURNED_FOR_REVISION
}

model Assignment {
  id String @id @default(uuid())

  reportId  String?
  report    SessionReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  title        String
  instructions String  @db.Text
  dueDate      DateTime?
  maxScore     Int     @default(100)

  status AssignmentStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions AssignmentSubmission[]

  @@index([studentId, status])
  @@index([teacherId, status])
  @@index([dueDate])
  @@map("assignments")
}

model AssignmentSubmission {
  id String @id @default(uuid())

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  content String? @db.Text
  fileUrl String?
  linkUrl String?

  status AssignmentSubmissionStatus @default(SUBMITTED)

  submittedAt DateTime @default(now())

  score              Int?
  feedback           String? @db.Text
  reviewedAt         DateTime?
  reviewedByTeacherId String?

  revisionRequested Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, studentId])
  @@index([studentId, status])
  @@index([assignmentId, status])
  @@map("assignment_submissions")
}